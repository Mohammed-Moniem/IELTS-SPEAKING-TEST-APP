#
# APPLICATION
#
APP_NAME=ielts-speaking-practice-api
APP_SCHEMA=http
APP_HOST=0.0.0.0
APP_PORT=4000
APP_ROUTE_PREFIX=/api/v1
APP_BANNER=true

#
# LOGGING
#
LOG_LEVEL=info
LOG_OUTPUT=dev

#
# PATH STRUCTURE
#
CONTROLLERS=src/api/controllers/**/*Controller.ts
MIDDLEWARES=src/api/middlewares/**/*Middleware.ts
INTERCEPTORS=src/api/interceptors/**/*Interceptor.ts
SUBSCRIBERS=src/api/subscribers/**/*Subscriber.ts
RESOLVERS=src/api/resolvers/**/*Resolver.ts

#
# GraphQL
#
GRAPHQL_ENABLED=false
GRAPHQL_ROUTE=/graphql
GRAPHQL_EDITOR=false

#
# Swagger
#
SWAGGER_ENABLED=true
SWAGGER_ROUTE=/swagger
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=1234

#
# Status Monitor
#
MONITOR_ENABLED=false
MONITOR_ROUTE=/monitor
MONITOR_USERNAME=admin
MONITOR_PASSWORD=1234

#
# Service API Protection & Rate Limiting
#
API_KEY=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CORS_ORIGIN=*


#
# Observability / Telemetry
#
TELEMETRY_ENABLED=false
TELEMETRY_SERVICE_NAME=x-service
TELEMETRY_TRACE_EXPORTER_URL=
TELEMETRY_DIAGNOSTICS_ENABLED=false
TELEMETRY_METRICS_ENABLED=false
TELEMETRY_METRICS_PORT=9464
TELEMETRY_METRICS_PATH=/metrics

#
# Health Checks
#
HEALTH_DEPENDENCY_CHECKS_ENABLED=true
HEALTH_SELF_DIAGNOSTICS_ENABLED=false
HEALTH_CACHE_CHECK_ENABLED=false
HEALTH_CACHE_SERVICE_NAME=cache
HEALTH_EVENT_LOOP_SAMPLE_MS=25

#
# MongoDB (Production)
#
MONGO_URL=mongodb://mongo:27017/ielts-speaking

# JWT configuration (replace secrets in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

#
# Encryption Configuration (for chat messages and PII data)
# Must be exactly 32 characters (256 bits) for AES-256
#
ENCRYPTION_KEY=dev-encryption-key-32-chars!!

#
# OpenAI Configuration (Set your real API key here)
#

## REPLACE THIS LINE IN .env:
OPENAI_API_KEY=your-openai-api-key-here
## REPLACE THIS LINE IN .env:

OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=800
OPENAI_TEMPERATURE=0.7
OPENAI_BASE_URL=https://api.openai.com/v1

#
# ElevenLabs Text-to-Speech
#
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=id-here
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SPEED=1.0

#
# RabbitMQ Configuration
#
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://localhost
RABBITMQ_EXCHANGE=service.exchange
RABBITMQ_QUEUE=service.queue
RABBITMQ_ROUTING_KEY=service.routing.key
RABBITMQ_PREFETCH=10
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_RETRIES=3
RABBITMQ_RETRY_DELAY=5000
RABBITMQ_STALE_DURATION=300000
RABBITMQ_ENCRYPTION_KEY=your-encryption-key-here
RABBITMQ_LOG_LEVEL=info

#
# Error Handling
#
ERROR_CODE_PREFIX=SERVICE
DEFAULT_ERROR_CODE=GLOBAL.UNMAPPED-ERROR
DEFAULT_ERROR_MSG='An unexpected error occurred'
DEFAULT_ERROR_DESCRIPTION='No additional information provided'
#