#
# APPLICATION
#
APP_NAME=ielts-speaking-practice-api
APP_SCHEMA=http
APP_HOST=0.0.0.0
APP_PORT=4000
APP_ROUTE_PREFIX=/api/v1
APP_BANNER=true

#
# LOGGING
#
LOG_LEVEL=info
LOG_OUTPUT=dev

#
# PATH STRUCTURE
#
CONTROLLERS=src/api/controllers/**/*Controller.ts
MIDDLEWARES=src/api/middlewares/**/*Middleware.ts
INTERCEPTORS=src/api/interceptors/**/*Interceptor.ts
SUBSCRIBERS=src/api/subscribers/**/*Subscriber.ts
RESOLVERS=src/api/resolvers/**/*Resolver.ts

#
# GraphQL
#
GRAPHQL_ENABLED=false
GRAPHQL_ROUTE=/graphql
GRAPHQL_EDITOR=false

#
# Swagger
#
SWAGGER_ENABLED=true
SWAGGER_ROUTE=/swagger
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=1234

#
# Status Monitor
#
MONITOR_ENABLED=false
MONITOR_ROUTE=/monitor
MONITOR_USERNAME=admin
MONITOR_PASSWORD=1234

#
# Service API Protection & Rate Limiting
#
API_KEY=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CORS_ORIGIN=*


#
# Observability / Telemetry
#
TELEMETRY_ENABLED=false
TELEMETRY_SERVICE_NAME=x-service
TELEMETRY_TRACE_EXPORTER_URL=
TELEMETRY_DIAGNOSTICS_ENABLED=false
TELEMETRY_METRICS_ENABLED=false
TELEMETRY_METRICS_PORT=9464
TELEMETRY_METRICS_PATH=/metrics

#
# Health Checks
#
HEALTH_DEPENDENCY_CHECKS_ENABLED=true
HEALTH_SELF_DIAGNOSTICS_ENABLED=false
HEALTH_CACHE_CHECK_ENABLED=false
HEALTH_CACHE_SERVICE_NAME=cache
HEALTH_EVENT_LOOP_SAMPLE_MS=25

#
# MongoDB (Production)
#
MONGO_URL=mongodb://mongo:27017/ielts-speaking

#
# Supabase (Primary Database + Storage)
#
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=no-verify
SUPABASE_STORAGE_CHAT_BUCKET=chat-files
SUPABASE_STORAGE_AUDIO_BUCKET=audio-recordings
SUPABASE_STORAGE_SIGNED_URL_EXPIRY=3600

#
# Database Read/Write Modes
#
DB_WRITE_MODE=supabase
DB_READ_MODE=supabase
DB_PARITY_LOGGING=false

#
# Storage Provider
#
STORAGE_PROVIDER=supabase

# JWT configuration (replace secrets in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

#
# Stripe Billing (Use test-mode keys locally)
#
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_DEFAULT_SUCCESS_URL=http://localhost:3000/app/billing?checkout=success
STRIPE_DEFAULT_CANCEL_URL=http://localhost:3000/app/billing?checkout=cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/app/billing
STRIPE_PRICE_PREMIUM_MONTHLY=price_replace_me
STRIPE_PRICE_PREMIUM_ANNUAL=price_replace_me
STRIPE_PRICE_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_PRO_ANNUAL=price_replace_me
STRIPE_PRICE_TEAM_MONTHLY=price_replace_me
STRIPE_PRICE_TEAM_ANNUAL=price_replace_me

#
# Partner Program Portal Links
#
PARTNER_REGISTRATION_URL=http://localhost:3000/app/partner
PARTNER_DASHBOARD_URL=http://localhost:3000/app/partner
PARTNER_TARGET_RECONCILE_ENABLED=true
PARTNER_TARGET_RECONCILE_HOUR_UTC=1
PARTNER_TARGET_RECONCILE_MINUTE_UTC=0
PARTNER_TARGET_RECONCILE_CHECK_INTERVAL_MS=900000

#
# Push Notifications (Expo mobile + FCM web)
#
PUSH_NOTIFICATIONS_ENABLED=true
EXPO_ACCESS_TOKEN=
PUSH_BROADCAST_ALLOWED_EMAILS=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
PUSH_CAMPAIGN_SCHEDULER_ENABLED=true
PUSH_CAMPAIGN_SWEEP_INTERVAL_MS=60000
PUSH_CAMPAIGN_FALLBACK_IMMEDIATE_DEFAULT=false

#
# Encryption Configuration (for chat messages and PII data)
# Must be exactly 32 characters (256 bits) for AES-256
#
ENCRYPTION_KEY=dev-encryption-key-32-chars!!

#
# OpenAI Configuration (Set your real API key here)
#

## REPLACE THIS LINE IN .env:
OPENAI_API_KEY=your-openai-api-key-here
## REPLACE THIS LINE IN .env:

OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_MAX_TOKENS=800
OPENAI_TEMPERATURE=0.7
OPENAI_BASE_URL=https://api.openai.com/v1

#
# ElevenLabs Text-to-Speech
#
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=id-here
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SPEED=1.0

#
# RabbitMQ Configuration
#
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://localhost
RABBITMQ_EXCHANGE=service.exchange
RABBITMQ_QUEUE=service.queue
RABBITMQ_ROUTING_KEY=service.routing.key
RABBITMQ_PREFETCH=10
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_RETRIES=3
RABBITMQ_RETRY_DELAY=5000
RABBITMQ_STALE_DURATION=300000
RABBITMQ_ENCRYPTION_KEY=your-encryption-key-here
RABBITMQ_LOG_LEVEL=info

#
# Error Handling
#
ERROR_CODE_PREFIX=SERVICE
DEFAULT_ERROR_CODE=GLOBAL.UNMAPPED-ERROR
DEFAULT_ERROR_MSG='An unexpected error occurred'
DEFAULT_ERROR_DESCRIPTION='No additional information provided'
#
