{
  "name": "nodejs-typescript-express-server",
  "version": "1.0.0",
  "description": "NodeJS TypeScript Express Server",
  "main": "src/app.ts",
  "scripts": {
    "start": "nps",
    "serve": "npm start serve",
    "lint": "eslint --config eslint.config.mjs \"src/**/*.ts\"",
    "test": "jest --coverage --no-cache",
    "coverage": "npm start test.unit.coverage",
    "build": "npm start build",
    "presetup": "npm install",
    "setup": "npm start config && npm start setup.script",
    "debug": "npm start serve",
    "lintfix": "eslint -c eslintrc.json --ext .ts src --fix",
    "prettier:fix": "prettier --write \"src/**/*.ts\"",
    "db:setup": "ts-node -e \"require('./test/utils/mongodb-setup').MongoDBSetup.initializeDatabase()\"",
    "db:cleanup": "ts-node -e \"require('./test/utils/mongodb-setup').MongoDBSetup.cleanupDatabase()\"",
    "db:check": "ts-node -e \"require('./test/utils/mongodb-setup').MongoDBSetup.checkConnection()\"",
    "db:migrate:supabase": "ts-node scripts/migrate-mongo-to-supabase.ts",
    "db:verify:parity": "ts-node scripts/verify-mongo-supabase-parity.ts",
    "seed:writing-bank": "ts-node -r tsconfig-paths/register scripts/seedWritingTaskBank.ts",
    "seed:reading-bank": "ts-node -r tsconfig-paths/register scripts/seedReadingTestBank.ts",
    "partners:backfill:influencers": "ts-node -r tsconfig-paths/register scripts/backfill-influencer-coupons-to-partners.ts",
    "partners:reconcile:targets": "ts-node -r tsconfig-paths/register scripts/reconcile-partner-targets.ts",
    "test:e2e:setup": "npm run db:setup",
    "test:e2e:cleanup": "npm run db:cleanup",
    "test:full": "npm run test:e2e:setup && npm test && npm run test:e2e:cleanup",
    "seed:achievements": "ts-node scripts/seedAchievements.ts",
    "seed:blog": "ts-node scripts/seed-blog-posts.ts",
    "perf:checkpoint6": "bash scripts/perf/run_checkpoint6_load.sh",
    "listening:pipeline": "ts-node -r tsconfig-paths/register scripts/listening-gen/run-pipeline.ts",
    "listening:pipeline:from": "ts-node -r tsconfig-paths/register scripts/listening-gen/run-pipeline.ts --from"
  },
  "keywords": [
    "NodeJS",
    "TypeScript",
    "express"
  ],
  "author": "Sayed M. Ali",
  "license": "ISC",
  "engines": {
    "node": ">=8.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.65.0",
    "@aws-sdk/client-s3": "3.901.0",
    "@aws-sdk/s3-request-presigner": "3.901.0",
    "@opentelemetry/api": "1.4.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.50.0",
    "@opentelemetry/resources": "1.9.0",
    "@opentelemetry/sdk-trace-base": "1.19.0",
    "@opentelemetry/sdk-trace-node": "1.19.0",
    "@opentelemetry/semantic-conventions": "1.9.0",
    "@supabase/supabase-js": "2.95.3",
    "@types/amqplib": "0.10.7",
    "@types/bcryptjs": "2.4.6",
    "@types/crypto-js": "4.2.2",
    "@types/multer": "2.0.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/eslint-plugin-tslint": "^7.0.2",
    "@typescript-eslint/parser": "^7.8.0",
    "amqplib": "0.10.9",
    "aws-sdk": "2.1692.0",
    "bcryptjs": "3.0.2",
    "body-parser": "^1.20.2",
    "chalk": "^3.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "crypto-js": "4.2.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "expo-server-sdk": "4.0.0",
    "express": "^4.19.2",
    "express-mongo-sanitize": "2.2.0",
    "express-rate-limit": "8.1.0",
    "figlet": "^1.7.0",
    "firebase-admin": "13.5.0",
    "form-data": "4.0.4",
    "helmet": "8.1.0",
    "hpp": "0.2.3",
    "http-status-codes": "^2.3.0",
    "jsonfile": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "mingo": "7.2.0",
    "moment": "^2.30.1",
    "mongodb": "5.9.2",
    "mongoose": "^8.3.4",
    "multer": "2.0.2",
    "nodemon": "^3.1.0",
    "nps": "^5.10.0",
    "nps-utils": "^1.7.0",
    "openai": "5.23.2",
    "pg": "8.16.3",
    "prom-client": "14.2.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.10.4",
    "socket.io": "4.8.1",
    "stripe": "19.0.0",
    "supertest": "^7.0.0",
    "trim-request-body": "1.0.1",
    "tslib": "^2.6.2",
    "typedi": "^0.8.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "xss": "1.0.15"
  },
  "overrides": {
    "fast-xml-parser": "5.3.6"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-typescript": "^7.24.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "1.3.2",
    "@types/express-rate-limit": "^5.1.3",
    "@types/hpp": "0.2.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.14",
    "@types/uuid": "^9.0.8",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "eslint-plugin-prettier": "5.5.4",
    "jest": "^29.7.0",
    "mock-express-request": "^0.2.2",
    "mock-express-response": "^0.3.0",
    "mongodb-memory-server": "^10.2.1",
    "prettier": "^3.3.2",
    "sinon": "^17.0.1",
    "ts-jest": "^29.1.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tslint": "^6.1.3",
    "typescript": "^5.4.5"
  }
}
