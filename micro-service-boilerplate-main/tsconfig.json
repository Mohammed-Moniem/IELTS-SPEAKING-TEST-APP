{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "pretty": true,
    "sourceMap": true,
    "outDir": "dist",
    "importHelpers": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@api/*": ["src/api/*"],
      "@services/*": ["src/api/services/*"],
      "@controllers/*": ["src/api/controllers/*"],
      "@middlewares/*": ["src/api/middlewares/*"],
      "@models/*": ["src/api/models/*"],
  "@dto/*": ["src/api/dto/*"],
      "@interfaces/*": ["src/api/Interface/*"],
      "@errors/*": ["src/api/errors/*"],
      "@responses/*": ["src/api/responses/*"],
      "@decorators/*": ["src/api/decorators/*"],
      "@loaders/*": ["src/loaders/*"],
      "@lib/*": ["src/lib/*"],
      "@env": ["src/env"],
      "@env/*": ["src/env/*"],
      "@examples/*": ["src/examples/*"]
    },
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": [
      "es5",
      "es6",
      "dom",
      "es2015.core",
      "es2015.collection",
      "es2015.generator",
      "es2015.iterable",
      "es2015.promise",
      "es2015.proxy",
      "es2015.reflect",
      "es2015.symbol",
      "es2015.symbol.wellknown",
      "esnext.asynciterable"
    ]
  }
}
