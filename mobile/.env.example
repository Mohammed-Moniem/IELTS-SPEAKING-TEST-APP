# API Configuration
# Copy this file to .env and update with your values

# API URL - Backend endpoint
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# Socket URL - WebSocket endpoint (same base as API, without /api/v1)
EXPO_PUBLIC_SOCKET_URL=http://localhost:4000

# API Key - Backend authentication key
EXPO_PUBLIC_API_KEY=your-api-key-here

# Sentry DSN - Error tracking
EXPO_PUBLIC_SENTRY_DSN=

# Optional: enable Expo Sentry build plugin (sourcemap upload + release linkage)
# If omitted, mobile runtime monitoring still works from EXPO_PUBLIC_SENTRY_DSN.
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_URL=https://sentry.io/

# Firebase native config files (required for @react-native-firebase on EAS/dev client)
# Keep files in the mobile project root and reference with relative paths.
GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist

# Recommended for stable mobile app identity across Firebase + EAS builds
# IOS_BUNDLE_IDENTIFIER=com.spokio.app
# ANDROID_PACKAGE_NAME=com.spokio.app

# Development Tips:
# 1. For local testing on physical device, replace localhost with your computer's IP
#    Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:4000/api/v1
# 2. Ensure mobile device and computer are on the same WiFi network
# 3. Check firewall settings if connection fails
