{
  "name": "spokio-web-saas",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:seo": "playwright test tests/e2e/seo-marketing.spec.ts",
    "test:seo:lighthouse": "npm run build && lhci autorun --config=.lighthouserc.js",
    "test:seo:ci": "npm run typecheck && npm run test:seo:lighthouse && npm run test:seo",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:real": "playwright test --config=playwright.real.config.ts",
    "test:e2e:real:headed": "playwright test --config=playwright.real.config.ts --headed",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.27",
    "firebase": "^12.4.0",
    "next": "^15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
